# JWT Configuration (REQUIRED - at least 32 characters)
JWT_SECRET=your-super-secret-key-here-at-least-32-chars

# Database
DB_CONNECTION=Server=(localdb)\mssqllocaldb;Database=PocketLedgerDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# API Port
API_PORT=5000
